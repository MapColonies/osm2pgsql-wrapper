{
  "name": "osm2pgsql-wrapper",
  "version": "4.0.0",
  "description": "wrapped osm2pgsql for creating and appending osm data into vector ecosystem",
  "main": "./src/index.ts",
  "scripts": {
    "test:unit": "jest --config=./tests/configurations/unit/jest.config.js",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "prelint:fix": "npm run format:fix",
    "prelint": "npm run format",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "tsc --noEmit && npm run test:unit",
    "prebuild": "npm run clean",
    "build": "tsc --project tsconfig.build.json && tsc-alias -p tsconfig.build.json && npm run assets:copy",
    "start": "npm run build && cd dist && node --import ./instrumentation.mjs ./index.js",
    "start:dev": "npm run build && cd dist && cross-env CONFIG_OFFLINE_MODE=true  node --enable-source-maps --import ./instrumentation.mjs ./index.js",
    "assets:copy": "copyfiles -f ./config/* ./dist/config && copyfiles ./package.json dist",
    "clean": "rimraf dist",
    "generate:openapi-types": "openapi-helpers ./openapi3.yaml ./src/openapi.d.ts --format --add-typed-request-handler",
    "prepare": "node .husky/install.mjs"
  },
  "directories": {
    "test": "tests"
  },
  "author": "MapColonies",
  "license": "ISC",
  "dependencies": {
    "@apideck/better-ajv-errors": "^0.3.6",
    "@aws-sdk/client-s3": "^3.39.0",
    "@godaddy/terminus": "^4.12.1",
    "@map-colonies/arstotzka-common": "^1.0.0",
    "@map-colonies/arstotzka-mediator": "^1.0.0",
    "@map-colonies/cleanup-registry": "^1.1.0",
    "@map-colonies/config": "^2.1.0",
    "@map-colonies/js-logger": "^2.0.0",
    "@map-colonies/read-pkg": "^1.0.0",
    "@map-colonies/schemas": "^1.6.0",
    "@map-colonies/telemetry": "^10.0.1",
    "@map-colonies/tile-calc": "^0.1.5",
    "@mapbox/sphericalmercator": "^1.2.0",
    "@opentelemetry/api": "^1.9.0",
    "@turf/boolean-valid": "^7.2.0",
    "@turf/turf": "^7.2.0",
    "ajv": "^8.17.1",
    "ajv-keywords": "^5.1.0",
    "axios": "^1.7.9",
    "concat-stream": "^2.0.0",
    "execa": "^5.1.1",
    "express": "^4.21.2",
    "lodash": "^4.17.21",
    "pg-boss": "^7.2.0",
    "prom-client": "^15.1.3",
    "qs": "^6.10.2",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "valid-url": "^1.0.9",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@map-colonies/commitlint-config": "^1.1.1",
    "@map-colonies/eslint-config": "^6.0.0",
    "@map-colonies/prettier-config": "0.0.1",
    "@map-colonies/tsconfig": "^1.0.1",
    "@swc/core": "^1.11.11",
    "@swc/jest": "^0.2.37",
    "@types/concat-stream": "^1.6.1",
    "@types/express": "^4.17.13",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.16",
    "@types/mapbox__sphericalmercator": "^1.2.0",
    "@types/valid-url": "^1.0.7",
    "@types/yargs": "^17.0.33",
    "copyfiles": "^2.4.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.25.1",
    "eslint-plugin-jest": "^28.11.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-create-mock-instance": "^2.0.0",
    "jest-html-reporters": "^3.1.7",
    "prettier": "^3.6.2",
    "pretty-quick": "^4.1.1",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.3.2",
    "tsc-alias": "^1.8.11",
    "typescript": "^5.8.2"
  }
}
